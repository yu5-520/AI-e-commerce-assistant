# Runtime mode
APP_ENV=production
DEMO_MODE=false

# Server runtime config
# Security default: FastAPI listens on localhost only.
# Public traffic should enter through Nginx on 80/443.
APP_HOST=127.0.0.1
APP_PORT=3000
APP_WORKERS=1
APP_RELOAD=false
PUBLIC_BASE_URL=http://47.118.29.46

# P0 SaaS identity defaults for demo scaffolding
DEFAULT_TENANT_ID=tenant_demo
DEFAULT_ORG_ID=org_demo
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
# SQLite is allowed only for local/demo. Production should use PostgreSQL + asyncpg.
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/ai_ecommerce
DEMO_DATABASE_URL=sqlite+aiosqlite:///./runtime/ai_ecommerce_demo.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis / Worker
REDIS_CACHE_URL=redis://127.0.0.1:6379/0
REDIS_QUEUE_URL=redis://127.0.0.1:6379/1
REDIS_LOCK_URL=redis://127.0.0.1:6379/2
WORKER_IMPORT_QUEUE=import_queue
WORKER_PROJECTION_QUEUE=projection_queue
WORKER_ALERT_QUEUE=alert_queue
WORKER_AGENT_QUEUE=agent_queue
WORKER_JOB_TIMEOUT_SECONDS=300
WORKER_MAX_RETRIES=3

# Upload / object storage placeholder
UPLOAD_MODE=local
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
PRESIGNED_UPLOAD_EXPIRE_SECONDS=900

# V4.5 / V5 LLM Gateway
# Keep false in demo / CI. When false, the product uses deterministic ActionPlan + mock LLM fallback.
LLM_ENABLED=false
LLM_MOCK_MODE=false
LLM_TRACE_ENABLED=true
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
LLM_TENANT_DAILY_TOKEN_QUOTA=200000

# Provider in config/model_providers.json
# Examples: openai, deepseek, qwen_dashscope, moonshot, zhipu, minimax, baichuan, stepfun, siliconflow, volcengine_ark, tencent_hunyuan, baidu_qianfan, custom
LLM_PROVIDER=deepseek

# Optional override model
LLM_MODEL=deepseek-chat

# Only needed when LLM_PROVIDER=custom or you want to override provider base url
LLM_BASE_URL=

# Use this generic key for all providers in GitHub Actions Secrets or local env.
# Provider-specific keys such as OPENAI_API_KEY or DEEPSEEK_API_KEY are also supported through config/model_providers.json.
LLM_API_KEY=

# Optional generation settings
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
LLM_MAX_TOKENS=1200

# Logs / audit
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_RETENTION_DAYS=365
TECH_LOG_RETENTION_DAYS=30
