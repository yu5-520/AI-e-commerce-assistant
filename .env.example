# AI ERP Operating Advisor environment example

# Runtime mode
APP_ENV=production
DEPLOYMENT_MODE=demo
DEMO_MODE=false
PUBLIC_BASE_URL=http://example.com

# Server runtime config
# Security default: FastAPI listens on localhost only.
# Public traffic should enter through Nginx on 80/443.
APP_HOST=127.0.0.1
APP_PORT=8000
APP_WORKERS=1
APP_RELOAD=false

# P0 SaaS identity defaults for demo scaffolding
DEFAULT_TENANT_ID=tenant_demo
DEFAULT_ORG_ID=org_demo
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# FastAPI / Nginx boundary security
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* http://localhost:*; frame-ancestors 'none'
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_EXEMPT_PREFIXES=/,/web_demo,/api/health

# Database
# SQLite is allowed only for local/demo. Production should use PostgreSQL + asyncpg.
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/ai_ecommerce
DEMO_DATABASE_URL=sqlite+aiosqlite:///./runtime/ai_ecommerce_demo.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis / Worker
WORKER_RUNTIME=sqlite
WORKER_FALLBACK_SQLITE=true
WORKER_QUEUE_NAME=default
WORKER_MAX_JOBS=4
WORKER_JOB_TIMEOUT_SECONDS=300
WORKER_KEEP_RESULT_SECONDS=3600
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/0
REDIS_QUEUE_URL=redis://127.0.0.1:6379/1
REDIS_LOCK_URL=redis://127.0.0.1:6379/2
WORKER_IMPORT_QUEUE=import_queue
WORKER_PROJECTION_QUEUE=projection_queue
WORKER_ALERT_QUEUE=alert_queue
WORKER_AGENT_QUEUE=agent_queue
WORKER_MAX_RETRIES=3

# Upload / object storage placeholder
UPLOAD_MODE=local
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
PRESIGNED_UPLOAD_EXPIRE_SECONDS=900

# LLM Gateway
# Keep mock in demo / CI. Product uses deterministic ActionPlan + mock LLM fallback when no provider is configured.
LLM_ENABLED=false
LLM_MOCK_MODE=false
LLM_PROVIDER=mock
LLM_MODEL=mock-json
LLM_BASE_URL=
LLM_API_KEY=
LLM_TRACE_ENABLED=true
LLM_TENANT_DAILY_QUOTA=200
LLM_TENANT_RATE_LIMIT_PER_MINUTE=30
LLM_BREAKER_FAILURE_THRESHOLD=3
LLM_BREAKER_COOLDOWN_SECONDS=300
LLM_CACHE_TTL_SECONDS=1800
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
LLM_MAX_TOKENS=1200

# Legacy / token quota compatibility
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
LLM_TENANT_DAILY_TOKEN_QUOTA=200000

# Logs / audit
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_RETENTION_DAYS=365
TECH_LOG_RETENTION_DAYS=30
TECH_LOG_REDACTION=true
