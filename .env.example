# Runtime mode
APP_ENV=production

# Server runtime config
# Security default: FastAPI listens on localhost only.
# Public traffic should enter through Nginx on 80/443.
APP_HOST=127.0.0.1
APP_PORT=3000
APP_WORKERS=1
APP_RELOAD=false
PUBLIC_BASE_URL=http://47.118.29.46

# Enable or disable API model call
LLM_ENABLED=false

# Provider in config/model_providers.json
# Examples: openai, deepseek, qwen_dashscope, moonshot, zhipu, minimax, baichuan, stepfun, siliconflow, volcengine_ark, tencent_hunyuan, baidu_qianfan, custom
LLM_PROVIDER=deepseek

# Optional override model
LLM_MODEL=deepseek-chat

# Only needed when LLM_PROVIDER=custom or you want to override provider base url
LLM_BASE_URL=

# Use this generic key for all providers in GitHub Actions Secrets or local env
LLM_API_KEY=

# Optional generation settings
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
