{
  "retrieval_chain_version": "0.1.0",
  "goal": "Retrieve only relevant proven patterns before generating a new ecommerce operation result.",
  "query_keys": [
    "platform",
    "mode",
    "category",
    "product",
    "user_goal",
    "price_band",
    "feedback_level"
  ],
  "priority_order": [
    "L4 effective patterns",
    "L3 executed patterns",
    "L2 liked candidate patterns"
  ],
  "knowledge_sources": [
    "modules/knowledge_base/title_patterns.md",
    "modules/knowledge_base/image_patterns.md",
    "modules/knowledge_base/sku_patterns.md",
    "modules/knowledge_base/price_patterns.md",
    "modules/knowledge_base/operation_cases.md"
  ],
  "rule": "Retrieve a small number of high relevance patterns. Do not send the whole knowledge base to the LLM."
}
