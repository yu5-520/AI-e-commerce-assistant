{
  "rag_chain_version": "0.1.0",
  "goal": "Connect user input, runtime modules, knowledge retrieval, vector retrieval, context pack, and LLM prompt assembly.",
  "stage": "structure-only",
  "steps": [
    "extract_rag_query",
    "read_active_runtime_modules",
    "retrieve_structured_knowledge",
    "retrieve_vector_similar_patterns",
    "rerank_retrieved_context",
    "build_context_pack",
    "assemble_llm_prompt",
    "fallback_if_retrieval_is_weak"
  ],
  "input_modules": [
    "modules/rag/query_schema.md",
    "modules/rag/retrieval_pipeline.md",
    "modules/rag/context_pack.md",
    "modules/rag/prompt_assembly.md",
    "modules/rag/fallback_rules.md"
  ],
  "linked_runtime_chains": [
    "runtime/module_chain.json",
    "runtime/knowledge_retrieval_chain.json",
    "runtime/vector_retrieval_chain.json"
  ],
  "rule": "RAG is not yet connected to active generation. It should later provide optional context before LLM generation without blocking the existing workflow."
}
