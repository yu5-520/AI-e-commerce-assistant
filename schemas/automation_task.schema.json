{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutomationTask",
  "type": "object",
  "required": ["task_id", "task_type", "risk_level", "requires_approval", "status"],
  "properties": {
    "task_id": { "type": "string" },
    "task_type": {
      "type": "string",
      "enum": [
        "daily_report",
        "sku_price_table",
        "activity_prepare_table",
        "customer_segmentation_report",
        "retention_task_list",
        "after_sales_analysis",
        "review_iteration_report"
      ]
    },
    "target_product_id": { "type": "string" },
    "target_customer_segment": { "type": "string" },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "requires_approval": { "type": "boolean" },
    "approval_status": { "type": "string", "enum": ["draft", "pending", "approved", "rejected"] },
    "input_snapshot": { "type": "object" },
    "ai_suggestion": { "type": "string" },
    "execution_result": { "type": "object" },
    "status": {
      "type": "string",
      "enum": ["draft", "pending_approval", "approved", "rejected", "running", "success", "failed", "rollback_required"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
