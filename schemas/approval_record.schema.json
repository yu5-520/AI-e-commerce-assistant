{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApprovalRecord",
  "type": "object",
  "required": ["approval_id", "task_id", "risk_level", "approval_status"],
  "properties": {
    "approval_id": { "type": "string" },
    "task_id": { "type": "string" },
    "user_id": { "type": "string" },
    "target_product_id": { "type": "string" },
    "target_customer_segment": { "type": "string" },
    "action_type": { "type": "string" },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "ai_reason": { "type": "string" },
    "risk_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approval_status": { "type": "string", "enum": ["pending", "approved", "rejected", "modified"] },
    "approved_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
